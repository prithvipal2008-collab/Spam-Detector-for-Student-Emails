        bins=20, ax=axes[1], alpha=0.7, label="Ham", color="#4CAF50"
    )
    df[df["label"] == "spam"]["msg_length"].hist(
        bins=20, ax=axes[1], alpha=0.7, label="Spam", color="#F44336"
    )
    axes[1].set_title("Message Length Distribution", fontsize=13, fontweight="bold")
    axes[1].set_xlabel("Message Length (characters)")
